{
  "manifest_version": 3,
  "name": "GetAIBD Page Assistant",
  "version": "1.0.0",
  "description": "Ask questions about any web page using the GetAIBD Developer API.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://getaibd.com/*", "https://mail.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["gmail-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "GetAIBD Page Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
